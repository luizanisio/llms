# ─────────────────────────────────────────────────────────────
#  .env — Configurações do Label Studio
#  Copie este arquivo como .env e ajuste os valores
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Label Studio — Admin ────────────────────────────────────
LS_ADMIN_EMAIL=seu@email.com
LS_ADMIN_PASSWORD=blabla

# ── Label Studio — API (preencher após 1º login) ───────────
# Acesse Account & Settings → Access Token → cole aqui
LS_API_KEY=

# ── Label Studio — URL base ────────────────────────────────
# Local:   http://localhost:8080
# Railway: https://seu-app.up.railway.app
LS_URL=http://localhost:8080

# ── Porta local ────────────────────────────────────────────
LS_PORT=8080
